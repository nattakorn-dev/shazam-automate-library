# Environment Variables for Music Manager
# Copy this to .env and fill in your values

# Shazam Tagger Settings
SHAZAM_DELAY=1.5
LOG_FILE=/config/music_process.log
INTERVAL=300

# System Settings
TZ=Asia/Bangkok
PYTHONUNBUFFERED=1

# Discogs API (optional)
DISCOGS_API_KEY=YOUR_KEY_HERE
